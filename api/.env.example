# Django
SECRET_KEY=change-this-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=core.settings.development

# Database
DB_NAME=rentaldb
DB_USER=rentaluser
DB_PASSWORD=rentalpass
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# CORS (comma-separated, no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Auth cookie / frontend link — see docs/AUTH-PLAN.md in web/
# Leave AUTH_COOKIE_DOMAIN blank in dev.
AUTH_COOKIE_DOMAIN=
FRONTEND_URL=http://localhost:3000

# Google/Apple sign-in — leave blank to disable social login in this env.
# Google: Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID (Web application).
# Apple: Apple Developer -> Certificates, IDs & Profiles -> Identifiers -> Services ID.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=

# Stripe (get from dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AWS S3 (leave blank in dev — uses local storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Email (Resend — resend.com/api-keys). "from" domain must be verified in
# your Resend account, or use the onboarding@resend.dev sandbox address
# (only delivers to the account owner's own email, not real users).
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=Kiphaus <onboarding@resend.dev>
SUPPORT_EMAIL=support@kiphaus.com
